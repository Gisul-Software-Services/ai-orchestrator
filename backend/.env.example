# development | production — production enables startup warnings for CORS / org gate
ENVIRONMENT=development

# MongoDB (same cluster for billing + Aaptor org read)
MONGODB_URI=mongodb://localhost:27017
BILLING_DB_NAME=gisul_billing
# Read-only Aaptor DB (collection: organizations)
ORGANIZATION_DB_NAME=organization_db

# Production / shared environments: require X-Org-Id that exists in organization_db for
# POST /api/v1/generate-*, enrich-dsa, and GET /api/v1/aiml-library/catalog/{id}/preview.
# For quick local prototyping you can override to false, but recommended default is true.
REQUIRE_VERIFIED_ORG_FOR_GENERATION=true
ADMIN_API_KEY=change-me

# Stored on usage_logs rows
API_VERSION=2.0.0

# Single assets root — gisul derives dsa-coding/ and aiml-data/ paths below it.
# Local (repo root):  .../gisul_model/assets
# Docker:             /app/assets
ASSETS_DIR=/absolute/path/to/gisul_model/assets

# AIML library: load first rows via OpenML (same as catalog load_code) for UI table preview
# Set false if the API host is offline or downloads are too slow
AIML_LIBRARY_DATA_PREVIEW=true
AIML_LIBRARY_PREVIEW_MAX_ROWS=20
AIML_LIBRARY_PREVIEW_MAX_CATALOG_ROWS=30000

# CORS: browser UI origins allowed to call the API (comma-separated).
# Read by backend_app and by api_gateway (lightweight proxy). Unset or * = all origins (dev).
# For production / before Aaptor goes live, set explicit origins, e.g.:
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gisul backend — loaded from backend/.env (run uvicorn with cwd=backend).
# Per-path DSA_/AIML_* vars are not used by gisul; use ASSETS_DIR only.

# --- MongoDB (same cluster: billing DB + read-only org DB) ---
MONGODB_URI=mongodb+srv://gisul2102_db_user:5cNJ1DcNCxwaJDaU@cluster0.dwcfp0l.mongodb.net/?appName=Cluster0
BILLING_DB_NAME=aaptor_model
ORGANIZATION_DB_NAME=organization_db

# Local docker Redis for dev; replace with hosted Redis URL in live.
REDIS_URL=redis://127.0.0.1:6379

# Gateway -> model-service upstream (local dev)
MODEL_SERVICE_URL=http://127.0.0.1:7001

# --- Asset files (repo-root assets/) ---
ASSETS_DIR=/root/gisul_model/assets

# --- vLLM runtime tuning (safe defaults for 8GB dev GPU; raise in prod GPUs) ---
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=1024
VLLM_MAX_NUM_SEQS=1

# Enforce that POST /api/v1/generate-* and preview calls only work for orgs present
# in organization_db.organizations (X-Org-Id header must match). This turns on the
# VerifiedOrgRequiredMiddleware gate.
REQUIRE_VERIFIED_ORG_FOR_GENERATION=true
ADMIN_API_KEY=change-me

# --- enrich_dsa.py (optional) ---
# DSA_ENRICH_INPUT=/path/to/LeetCodeDataset-train.jsonl
# DSA_ENRICH_OUTPUT=/path/to/dsa_enriched.json
# ENRICH_API_URL=http://localhost:9000/api/v1/enrich-dsa

# --- build_*_faiss.py (optional) ---
# AIML_ASSET_DIR=/root/gisul_model/assets/aiml-data
# DSA_ASSET_DIR=/root/gisul_model/assets/dsa-coding

# Copy to `.env.local` and adjust. `NEXT_PUBLIC_*` is inlined at build time — restart `next dev` after edits.

# FastAPI base URL (no trailing slash, no /api/v1). Must match where the browser can reach the API.
# Examples:
#   Local:     http://127.0.0.1:9000
#   LAN IP:    http://192.168.1.10:9000
#   Production: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE=http://127.0.0.1:9000

# Default org for playground when the Org ID field is empty (optional)
# NEXT_PUBLIC_PLAYGROUND_ORG_ID=ORG001

# Optional: monthly token cap for the usage dashboard gauge (UI only)
# NEXT_PUBLIC_ORG_MONTHLY_TOKEN_BUDGET=1000000

# --- Admin console (server-side only; NEVER expose these in NEXT_PUBLIC_*) ---
# ADMIN_TOKEN is the login secret accepted by /api/admin/auth.
# ADMIN_SESSION_SECRET signs the httpOnly admin session cookie. If omitted,
# the app falls back to ADMIN_TOKEN, but using a dedicated secret is safer.
# ADMIN_API_KEY is attached server-side by /api/admin/* proxy routes as X-Api-Key
# when forwarding to the gateway (http://backend-api:7000 in docker-compose).
ADMIN_TOKEN=change-me
ADMIN_SESSION_SECRET=change-me
ADMIN_API_KEY=change-me

# Optional override for the gateway base URL (defaults to http://backend-api:7000)
# GATEWAY_BASE_URL=http://127.0.0.1:7000

# Copy to .env and fill in values. Used by backend.model_app.core.settings (pydantic-settings).
# Do not commit real credentials.

# Required — same Mongo cluster pattern as gateway (billing / usage if applicable)
MONGODB_URI=mongodb://localhost:27017

# Billing database name (usage logs, etc.)
BILLING_DB_NAME=aaptor_model

# Optional — not read by model_app today; gateway uses ORGANIZATION_DB_NAME in backend/.env.
# Keep here only if you want one shared template across services.
# ORGANIZATION_DB_NAME=organization_db

# Redis (job / cache); compose default is redis://redis:6379
REDIS_URL=redis://redis:6379

# Hugging Face model id for vLLM
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ

# LLM backend selection:
# - vllm   (default): run vLLM inside this container (Linux + NVIDIA)
# - ollama: call Ollama running elsewhere (Mac testing)
LLM_BACKEND=vllm

# Ollama settings (used when LLM_BACKEND=ollama).
# From Docker containers on macOS: host.docker.internal points to the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Repo assets (DSA FAISS, AIML catalog/index). Docker sets /app/assets.
ASSETS_DIR=/absolute/path/to/gisul_model/assets

# API version string returned on usage metadata paths
API_VERSION=2.0.0

# Inference batching
BATCH_SIZE_MAX=2
BATCH_TIMEOUT=0.5

# AIML library table preview (OpenML fetch)
AIML_LIBRARY_DATA_PREVIEW=true
AIML_LIBRARY_PREVIEW_MAX_ROWS=20

# vLLM — tune for GPU memory (see ModelSettings defaults)
VLLM_GPU_MEMORY_UTILIZATION=0.86
VLLM_MAX_MODEL_LEN=1024
VLLM_MAX_NUM_SEQS=1
